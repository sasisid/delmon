<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cat_card"
    android:layout_width="match_parent"
    android:layout_height="150dp"
    android:layout_margin="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    app:cardUseCompatPadding="false">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cat_lay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#85BDEA"
        android:clipChildren="false"
        android:clipToPadding="false">

        <TextView
            android:id="@+id/cat_title"
            style="@style/semi_bold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="12dp"
            android:text="@string/title"
            android:textAlignment="viewStart"
            android:textColor="@color/white"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/cat_num"
            style="@style/semi_bold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="4dp"
            android:text="@string/title"
            android:textAlignment="viewStart"
            android:textColor="#CCFFFFFF"
            android:textSize="22sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cat_title" />

        <!-- Anchor to bottom-end; negative margins keep artwork tucked in the corner (original layout). -->
        <ImageView
            android:id="@+id/cat_img"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginEnd="-20dp"
            android:layout_marginBottom="-30dp"
            android:scaleType="fitCenter"
            android:src="@drawable/dummy_cat"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
